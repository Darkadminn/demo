<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="obyv010.MainWindow"
        Title="ООО «Обувь» - окно авторизации"
		MinHeight="450"
		MaxHeight="450"
		MinWidth="500"
		MaxWidth="500"
		Icon="/images/Icon.ico"
		Background="White">

        <Grid>
        	<Grid.RowDefinitions>
            	<RowDefinition Height="70"/>
				<RowDefinition Height="*"/>
        	</Grid.RowDefinitions>

			<StackPanel Orientation="Horizontal" Grid.Row="0" Margin="10">
				<Image Height="50" Width="50" Source="/images/Icon.png" Margin="0,0,100,0"></Image>
				<TextBlock FontSize="32" FontFamily="Times New Roman">Авторизация</TextBlock>
			</StackPanel>

			<StackPanel Grid.Row="1" Width="300" Margin="10" Orientation="Vertical" HorizontalAlignment="Center">
				<TextBlock Width="200" FontSize="16" FontFamily="Times New Roman">Логин</TextBlock>
				<TextBox Width="200" Name="Login" FontSize="16" FontFamily="Times New Roman" Background="#7FFF00" Margin="0,0,0,30"></TextBox>
				<TextBlock Width="200" FontSize="16" FontFamily="Times New Roman">Пароль</TextBlock>
				<TextBox Width="200" Name="Password" FontSize="16" FontFamily="Times New Roman" Background="#7FFF00" PasswordChar="*" Margin="0,0,0,30"></TextBox>
				<Button Width="200" Height="30" HorizontalContentAlignment="Center" HorizontalAlignment="Center" FontSize="16" FontFamily="Times New Roman" Background="#00FA9A" Click="ButtonClickSignUp" Margin="0,0,0,10">Войти</Button>
				<Button Width="200" Height="30" HorizontalContentAlignment="Center" HorizontalAlignment="Center" FontSize="16" FontFamily="Times New Roman" Background="#00FA9A" Click="ButtonClickSignUpGuest" Margin="0,0,0,10">Войти как гость</Button>
				<Button Width="200" Height="30" HorizontalContentAlignment="Center" HorizontalAlignment="Center" FontSize="16" FontFamily="Times New Roman" Background="#00FA9A" Click="ButtonClickExit" Margin="0,0,0,10">Выйти</Button>
				<TextBlock Name="Messages" IsVisible="False" FontSize="16" Foreground="Red" HorizontalAlignment="Center" FontFamily="Times New Roman"></TextBlock>
			</StackPanel>
        </Grid>
</Window>
